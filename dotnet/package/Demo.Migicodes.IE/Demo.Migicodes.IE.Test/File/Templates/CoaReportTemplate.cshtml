@using Demo.Migicodes.IE.Dto
@using System.Linq
@using System.Collections.Generic

<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8" />
    <title></title>
    <style type="text/css">
        body {
            font-family: SimSun !important;
        }

        p {
            margin: 0px;
        }

        footer {
            color: #333;
            font-size: 1.2rem;
            margin-bottom: 1.5rem;
            margin-right: 5%;
            margin-top: 1.2rem;
            text-align: right;
        }

        table, td {
            border: 1px solid #444;
            border-collapse: collapse;
            height: 2rem;
            padding: 5px;
        }

        .evenNum {
            margin-bottom: 8%;
            padding-top: 10%;
        }

        #ResultList {
            border: 0;
        }

            #ResultList td {
                border: 0;
            }
    </style>
</head>
<body style="position:relative;">
    <img src="http://192.168.2.144:8070/Content/Index/img/logo.png" />
    <h3>@Model.Data.DeptName</h3>
    <h3>@Model.Data.CoaTitle</h3>
    <table>
        <tr>
            <td>检品名称</td>
            <td>@Model.Data.SampleName</td>
            <td>批号</td>
            <td>@Model.Data.BatchName</td>
        </tr>
        <tr>
            <td>规格</td>
            <td>@Model.Data.Guige</td>
            <td>生产日期</td>
            <td>@Model.Data.Guige</td>
        </tr>
        <tr>
            <td>数量</td>
            <td>@Model.Data.Ct_Smp_Db_Quantity</td>
            <td>有效期至</td>
            <td>@Model.Data.Expiry_Date</td>
        </tr>
        <tr>
            <td>包装规格</td>
            <td>@Model.Data.BaoZhuangGuiGe</td>
            <td>检验日期</td>
            <td>@Model.Data.JianYan_Date</td>
        </tr>
        <tr>
            <td>分析号</td>
            <td>@Model.Data.FenXiHao</td>
            <td>报告日期</td>
            <td>@Model.Data.BaoGao_Date</td>
        </tr>
        <tr>
            <td>检测依据：</td>
            <td colspan="3">@Model.Data.TestAccording</td>
        </tr>
        <tr>
            <td colspan="4">
                <table id="ResultList">
                    <tr>
                        <td>检测项目</td>
                        <td>标准规定</td>
                        <td>检测结果</td>
                        <td>结论</td>
                    </tr>
                    @{
                        List<CoaResult> coaResultList = Model.Data.CoaResults;
                        @foreach (var item in coaResultList.Select(m => m.AnalysisType).Distinct())
                        {
                            <tr>
                                <td>【@item】</td>
                                <td></td>
                                <td></td>
                                <td></td>
                            </tr>

                            var list = coaResultList.Where(m => m.AnalysisType == item).ToList();
                            @for (int i = 0; i < list.Count; i++)
                            {
                                <tr>
                                    @{
                                        var itemText = list.Count == 1 ? "" : list[i].Item;
                                        <td>@itemText</td>
                                        <td>@list[i].Guifan</td>
                                        <td>@list[i].Data</td>
                                        <td>@list[i].JieLun</td>
                                    }
                                </tr>
                            }
                        }
                    }
                </table>
            </td>
        </tr>
    </table>

    <div>结论:本品按国家食品药品监督管理局标准YBH01212015标准检验，结果：符合规定</div>
    @*<div style="margin-top:50px;">报告人/日期：@Model.Data.ReportBy</div>*@
</body>
</html>
